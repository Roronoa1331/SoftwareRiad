# MySQL relational database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=kg_user
MYSQL_PASSWORD=kg_password
MYSQL_DATABASE=cultural_relics_kg

# Neo4j graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Crawler settings
MUSEUM_TARGET=met
CRAWL_MAX_OBJECTS=100
CRAWL_DELAY_SECONDS=0.2
IMAGE_DOWNLOAD_DIR=./data/images

# API server
API_HOST=0.0.0.0
API_PORT=8000
